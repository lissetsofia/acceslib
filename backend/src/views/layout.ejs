<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ACCESSLIB | <%= title || "Panel" %></title>

  <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css" />
<link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.min.css" />

  <!-- AdminLTE -->
 <link rel="stylesheet" href="/vendor/admin-lte/dist/css/adminlte.min.css" />

  <!-- Si ya los tienes en /vendor, déjalos; si no, luego los agregamos -->
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.min.css" />
</head>

<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
<div class="app-wrapper">

  <!-- Navbar -->
  <nav class="app-header navbar navbar-expand bg-body">
    <div class="container-fluid">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
            <i class="bi bi-list"></i>
          </a>
        </li>
        <li class="nav-item d-none d-md-block">
          <a href="/admin/dashboard" class="nav-link">Panel</a>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <span id="apiStatus" class="badge text-bg-secondary me-2">API: ...</span>
        </li>
      </ul>
    </div>
  </nav>

  <!-- Sidebar -->
  <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    <div class="sidebar-brand">
      <a href="/admin/dashboard" class="brand-link">
        <span class="brand-text fw-light">ACCESSLIB</span>
      </a>
    </div>

    <div class="sidebar-wrapper">
      <nav class="mt-2">
        <ul class="nav sidebar-menu flex-column" role="menu">
          <li class="nav-item">
            <a href="/admin/dashboard" class="nav-link <%= page==='dashboard'?'active':'' %>">
              <i class="nav-icon bi bi-speedometer2"></i>
              <p>Dashboard</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/pcs" class="nav-link <%= page==='pcs'?'active':'' %>">
              <i class="nav-icon bi bi-pc-display"></i>
              <p>PCs</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/usuarios" class="nav-link <%= page==='usuarios'?'active':'' %>">
              <i class="nav-icon bi bi-people"></i>
              <p>Usuarios</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/reportes" class="nav-link <%= page==='reportes'?'active':'' %>">
              <i class="nav-icon bi bi-clipboard-data"></i>
              <p>Reportes</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/configuracion" class="nav-link <%= page==='configuracion'?'active':'' %>">
              <i class="nav-icon bi bi-gear"></i>
              <p>Configuración</p>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </aside>

  <!-- Contenido -->
  <main class="app-main">
    <div class="app-content-header">
      <div class="container-fluid">
        <h3 class="mb-0"><%= title || "" %></h3>
      </div>
    </div>

    <div class="app-content">
      <div class="container-fluid">
        <%- body %>
      </div>
    </div>
  </main>

  <footer class="app-footer">
    <div class="float-end d-none d-sm-inline">Beta</div>
    <strong>ACCESSLIB</strong> — Panel Administrador
  </footer>

</div>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/vendor/admin-lte/dist/js/adminlte.min.js"></script>


<script>
  // Badge API (solo para comprobar que el backend está vivo)
  (async () => {
    const badge = document.getElementById("apiStatus");
    try {
      const r = await fetch("/api/health");
      if (!r.ok) throw new Error();
      const data = await r.json();
      badge.className = "badge text-bg-success me-2";
      badge.textContent = "API: OK (DB=" + data.db + ")";
    } catch {
      badge.className = "badge text-bg-danger me-2";
      badge.textContent = "API: ERROR";
    }
  })();
</script>

</body>
</html>